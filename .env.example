# Multilingual Symptom Chatbot - Environment variables
# Copy to .env and fill in values

# Required for JWT (set a strong secret in production)
SECRET_KEY=change-me-in-production

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=chatbot_db

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Server (optional)
HOST=0.0.0.0
PORT=8000

# Languages (comma-separated)
SUPPORTED_LANGUAGES=en,hi,fr,es,de

# Optional: Whisper API (if using OpenAI API instead of local Whisper)
# OPENAI_API_KEY=
